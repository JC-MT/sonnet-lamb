---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import content from "./../content/doula/homepage.json";
const images = import.meta.glob('../assets/doula/*', { eager: true }) as Record<string, { default: ImageMetadata }>;
const heroImage = images[content.image]?.default;
---

<BaseLayout
  title={content.seo.title}
  description={content.seo.description}
>
  <section
    class="max-w-6xl mx-auto md:px-5 md:pb-5 items-center justify-center flex flex-col md:flex-row gap-8 md:gap-10 lg:gap-16 text-fg"
  >
    <div class="w-full md:w-2/3 relative">
      <Image
        priority
        src={heroImage}
        alt="Sonnet Lamb"
        class="md:rounded-lg w-full brightness-70 object-cover md:h-[700px]"
        layout="constrained"
      />
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="grid gap-2 px-1 md:px-10 lg:px-20">
          <h1 class="text-4xl font-medium text-center text-footer uppercase">
            {content.overImageTitle}
          </h1>
          <p
            class="flex items-center text-base font-normal text-center text-footer uppercase"
          >
            {content.overImageProps.map((prop, index) => (
              <>
                {prop}
                {index < content.overImageProps.length - 1 && (
                  <span class="mx-3">|</span>
                )}
              </>
            ))}
          </p>
        </div>
      </div>
    </div>
    <div class="w-full md:w-1/2 px-5 md:px-0 grid gap-4 md:gap-6">
      <div class="grid gap-1">
        <p class="text-sm font-medium uppercase tracking-tight">{content.eyebrow}</p>
        <p class="text-3xl md:text-4xl font-extralight">
          {content.oneLinerText}
        </p>
      </div>
      <hr class="border-t border-accent" />
      <p class="text-base md:text-lg">
        {content.description}
      </p>
      <a
        class="mb-10 md:mb-0 transition-all duration-300 rounded-[50px] hover:bg-accent border hover:text-white border-accent px-5 py-2.5 w-full md:w-fit text-center"
        href="/contact"
      >
        Schedule an Interview
      </a>
    </div>
  </section>
</BaseLayout>
