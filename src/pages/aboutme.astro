---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import DoulaGallery from "../components/DoulaGallery.astro";
import content from "./../content/doula/aboutme.json";
const images = import.meta.glob("../assets/doula/*", { eager: true }) as Record<
  string,
  { default: ImageMetadata }
>;
const mainImage = images[content.images[0]]?.default;
const galleryImages = content.images
  .slice(1)
  .map((img) => images[img]?.default);
---

<BaseLayout title={content.seo.title} description={content.seo.description}>
  <section
    class="max-w-6xl mx-auto justify-center flex flex-col md:flex-row gap-5 md:gap-10 lg:gap-16 px-5 pb-5 text-fg"
  >
    <div>
      <Image
        class="h-full w-full md:h-[550px] object-cover rounded-lg md:mb-5"
        alt="Sonnet Lamb Smiling"
        layout="constrained"
        src={mainImage}
        priority
      />
      <DoulaGallery
        galleryImages={galleryImages}
        credentials={content.credentials}
        containerClass="hidden gap-5 md:grid grid-cols-2"
      />
    </div>
    <div
      class="flex flex-col gap-3 md:gap-5 max-w-2xl text-left prose [&>h1]:text-center"
      data-html
      set:html={content.content}
    />
    <DoulaGallery
      galleryImages={galleryImages}
      credentials={content.credentials}
      containerClass="md:hidden gap-2 grid grid-cols-2"
    />
  </section>
  <script>
    // Number → word for the years-married count (small, slowly growing).
    const NUMBER_WORDS = [
      "zero",
      "one",
      "two",
      "three",
      "four",
      "five",
      "six",
      "seven",
      "eight",
      "nine",
      "ten",
      "eleven",
      "twelve",
      "thirteen",
      "fourteen",
      "fifteen",
      "sixteen",
      "seventeen",
      "eighteen",
      "nineteen",
      "twenty",
      "twenty-one",
      "twenty-two",
      "twenty-three",
      "twenty-four",
    ];

    class HarvestAge extends HTMLElement {
      static BIRTH_YEAR = 2024;
      static BIRTH_MONTH = 7;

      connectedCallback() {
        const now = new Date();
        const months =
          (now.getFullYear() - HarvestAge.BIRTH_YEAR) * 12 +
          (now.getMonth() - HarvestAge.BIRTH_MONTH);

        if (months < 0) return;

        if (months < 24) {
          this.textContent = `${months} month old`;
        } else {
          const years = Math.floor(months / 12);
          this.textContent = `${years} year old`;
        }
      }
    }

    class MarriedYears extends HTMLElement {
      static MARRIED_YEAR = 2021;

      connectedCallback() {
        const now = new Date();
        const years = now.getFullYear() - MarriedYears.MARRIED_YEAR;
        this.textContent = this.toWords(years);
      }
      toWords = (number: number) => NUMBER_WORDS[number] ?? String(number);
    }

    customElements.define("harvest-age", HarvestAge);
    customElements.define("married-years", MarriedYears);
  </script>
</BaseLayout>
