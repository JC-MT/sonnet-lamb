---
const { title, description } = Astro.props;
import Head from "../components/Head.astro";
import Header from "../layouts/Nav.astro";
import Footer from "../layouts/Footer.astro";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
// @ts-expect-error - side-effect CSS import, no type declarations
import "@fontsource-variable/montserrat";

const siteTitle = `Sonnet Lamb${title ? ` - ${title}` : ""}`;
const pathname = Astro.url.pathname;
const theme =
  pathname === "/acting" || pathname.startsWith("/acting/")
    ? "acting"
    : "earthy";
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <Head title={siteTitle} description={description} />
    <ClientRouter />
  </head>
  <body class="size-full font-light bg-bg text-fg">
    <Header />
    <main class="bg-bg">
      <slot />
    </main>
    <Footer />
  </body>
</html>
